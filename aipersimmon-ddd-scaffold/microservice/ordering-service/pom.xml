<?xml version="1.0" encoding="UTF-8"?>
<project xmlns="http://maven.apache.org/POM/4.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 https://maven.apache.org/xsd/maven-4.0.0.xsd">
  <modelVersion>4.0.0</modelVersion>

  <parent>
    <groupId>com.example</groupId>
    <artifactId>microservice</artifactId>
    <version>0.0.1-SNAPSHOT</version>
    <relativePath>../pom.xml</relativePath>
  </parent>

  <!--
    The ordering service: a standalone deployable for the ordering bounded context.
    It places orders, publishes OrderPlaced over the transactional outbox to Kafka,
    consumes StockReserved / StockReservationFailed from Kafka (inbox-guarded), and
    runs the order-fulfilment saga to confirm or cancel the order. Domain events are
    in-process; cross-service events go over the broker.
  -->
  <artifactId>ordering-service</artifactId>
  <name>ordering-service</name>
  <description>Ordering bounded context as a standalone service.</description>

  <dependencies>
    <dependency><groupId>${project.groupId}</groupId><artifactId>contracts</artifactId></dependency>

    <dependency><groupId>com.aipersimmon.ddd</groupId><artifactId>aipersimmon-ddd-core</artifactId></dependency>
    <dependency><groupId>com.aipersimmon.ddd</groupId><artifactId>aipersimmon-ddd-application</artifactId></dependency>
    <dependency><groupId>com.aipersimmon.ddd</groupId><artifactId>aipersimmon-ddd-saga</artifactId></dependency>
    <!-- In-process domain events. -->
    <dependency><groupId>com.aipersimmon.ddd</groupId><artifactId>aipersimmon-ddd-events-spring</artifactId></dependency>
    <!-- Reliable integration events over Kafka: outbox writer + relay, inbox, Kafka transport. -->
    <dependency><groupId>com.aipersimmon.ddd</groupId><artifactId>aipersimmon-ddd-outbox-jdbc</artifactId></dependency>
    <dependency><groupId>com.aipersimmon.ddd</groupId><artifactId>aipersimmon-ddd-inbox-jdbc</artifactId></dependency>
    <dependency><groupId>com.aipersimmon.ddd</groupId><artifactId>aipersimmon-ddd-messaging-kafka</artifactId></dependency>

    <dependency>
      <groupId>org.springframework.boot</groupId>
      <artifactId>spring-boot-starter-web</artifactId>
    </dependency>
    <dependency>
      <groupId>com.h2database</groupId>
      <artifactId>h2</artifactId>
      <scope>runtime</scope>
    </dependency>

    <dependency>
      <groupId>org.springframework.boot</groupId>
      <artifactId>spring-boot-starter-test</artifactId>
      <scope>test</scope>
    </dependency>
    <dependency>
      <groupId>com.aipersimmon.ddd</groupId>
      <artifactId>aipersimmon-ddd-archunit</artifactId>
      <scope>test</scope>
    </dependency>
  </dependencies>

  <build>
    <plugins>
      <plugin>
        <groupId>org.springframework.boot</groupId>
        <artifactId>spring-boot-maven-plugin</artifactId>
        <!-- Give the executable jar a classifier so the plain jar stays the main
             artifact and the e2e-tests module can depend on this service's classes. -->
        <configuration>
          <classifier>boot</classifier>
        </configuration>
      </plugin>
    </plugins>
  </build>
</project>
