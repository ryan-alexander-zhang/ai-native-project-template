<?xml version="1.0" encoding="UTF-8"?>
<project xmlns="http://maven.apache.org/POM/4.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 https://maven.apache.org/xsd/maven-4.0.0.xsd">
  <modelVersion>4.0.0</modelVersion>

  <parent>
    <groupId>com.example</groupId>
    <artifactId>microservice</artifactId>
    <version>0.0.1-SNAPSHOT</version>
    <relativePath>../pom.xml</relativePath>
  </parent>

  <!--
    The inventory service: a standalone deployable for the inventory bounded
    context. It consumes OrderPlaced from Kafka (inbox-guarded bridge, republished
    in process to its listener), reserves stock, and publishes StockReserved or
    StockReservationFailed back over the transactional outbox to Kafka. No web
    endpoint: it is driven entirely by messages.
  -->
  <artifactId>inventory-service</artifactId>
  <name>inventory-service</name>
  <description>Inventory bounded context as a standalone service.</description>

  <dependencies>
    <dependency><groupId>${project.groupId}</groupId><artifactId>contracts</artifactId></dependency>

    <dependency><groupId>com.aipersimmon.ddd</groupId><artifactId>aipersimmon-ddd-core</artifactId></dependency>
    <dependency><groupId>com.aipersimmon.ddd</groupId><artifactId>aipersimmon-ddd-application</artifactId></dependency>
    <!-- CQRS: the ReserveStock command and the Spring bus that routes to its handler. -->
    <dependency><groupId>com.aipersimmon.ddd</groupId><artifactId>aipersimmon-ddd-cqrs</artifactId></dependency>
    <dependency><groupId>com.aipersimmon.ddd</groupId><artifactId>aipersimmon-ddd-cqrs-spring</artifactId></dependency>
    <!-- Reliable integration events over Kafka: outbox writer + relay, inbox, Kafka transport. -->
    <dependency><groupId>com.aipersimmon.ddd</groupId><artifactId>aipersimmon-ddd-outbox-jdbc</artifactId></dependency>
    <dependency><groupId>com.aipersimmon.ddd</groupId><artifactId>aipersimmon-ddd-inbox-jdbc</artifactId></dependency>
    <dependency><groupId>com.aipersimmon.ddd</groupId><artifactId>aipersimmon-ddd-messaging-kafka</artifactId></dependency>

    <dependency>
      <groupId>com.h2database</groupId>
      <artifactId>h2</artifactId>
      <scope>runtime</scope>
    </dependency>

    <dependency>
      <groupId>org.springframework.boot</groupId>
      <artifactId>spring-boot-starter-test</artifactId>
      <scope>test</scope>
    </dependency>
    <dependency>
      <groupId>com.aipersimmon.ddd</groupId>
      <artifactId>aipersimmon-ddd-archunit</artifactId>
      <scope>test</scope>
    </dependency>
  </dependencies>

  <build>
    <plugins>
      <plugin>
        <groupId>org.springframework.boot</groupId>
        <artifactId>spring-boot-maven-plugin</artifactId>
        <!-- Give the executable jar a classifier so the plain jar stays the main
             artifact and the e2e-tests module can depend on this service's classes. -->
        <configuration>
          <classifier>boot</classifier>
        </configuration>
      </plugin>
    </plugins>
  </build>
</project>
