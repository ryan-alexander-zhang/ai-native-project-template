<?xml version="1.0"?>
<!-- Registers the histogramQuantile UDF that init-clickhouse drops into user_scripts. SigNoz uses
     it to compute quantiles from histogram metrics. Standard SigNoz local-deploy file. -->
<functions>
    <function>
        <type>executable</type>
        <name>histogramQuantile</name>
        <return_type>Float64</return_type>
        <argument>
            <type>Array(Float64)</type>
            <name>buckets</name>
        </argument>
        <argument>
            <type>Array(Float64)</type>
            <name>counts</name>
        </argument>
        <argument>
            <type>Float64</type>
            <name>quantile</name>
        </argument>
        <format>CSV</format>
        <command>histogramQuantile</command>
    </function>
</functions>
