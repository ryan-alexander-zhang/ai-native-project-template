<?xml version="1.0" encoding="UTF-8"?>
<project xmlns="http://maven.apache.org/POM/4.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 https://maven.apache.org/xsd/maven-4.0.0.xsd">
  <modelVersion>4.0.0</modelVersion>

  <parent>
    <groupId>com.example</groupId>
    <artifactId>multi-module</artifactId>
    <version>0.0.1-SNAPSHOT</version>
    <relativePath>../pom.xml</relativePath>
  </parent>

  <!--
    The bootstrap module: the Spring Boot application that assembles every layer
    into one deployable, and the home of the architecture tests that verify the
    whole context (layering rules via bytecode, package-info presence via source).
  -->
  <artifactId>start</artifactId>
  <name>start</name>
  <description>Spring Boot bootstrap and architecture tests for the ordering context.</description>

  <dependencies>
    <dependency><groupId>${project.groupId}</groupId><artifactId>ordering-api</artifactId></dependency>
    <dependency><groupId>${project.groupId}</groupId><artifactId>ordering-domain</artifactId></dependency>
    <dependency><groupId>${project.groupId}</groupId><artifactId>ordering-application</artifactId></dependency>
    <dependency><groupId>${project.groupId}</groupId><artifactId>ordering-infrastructure</artifactId></dependency>
    <dependency><groupId>${project.groupId}</groupId><artifactId>ordering-adapter</artifactId></dependency>
    <dependency><groupId>${project.groupId}</groupId><artifactId>ordering-process-jdbc</artifactId></dependency>

    <dependency><groupId>${project.groupId}</groupId><artifactId>inventory-api</artifactId></dependency>
    <dependency><groupId>${project.groupId}</groupId><artifactId>inventory-domain</artifactId></dependency>
    <dependency><groupId>${project.groupId}</groupId><artifactId>inventory-application</artifactId></dependency>
    <dependency><groupId>${project.groupId}</groupId><artifactId>inventory-infrastructure</artifactId></dependency>
    <dependency><groupId>${project.groupId}</groupId><artifactId>inventory-adapter</artifactId></dependency>

    <dependency><groupId>${project.groupId}</groupId><artifactId>payment-api</artifactId></dependency>
    <dependency><groupId>${project.groupId}</groupId><artifactId>payment-domain</artifactId></dependency>
    <dependency><groupId>${project.groupId}</groupId><artifactId>payment-application</artifactId></dependency>
    <dependency><groupId>${project.groupId}</groupId><artifactId>payment-adapter</artifactId></dependency>

    <!-- In-process synchronous transport for both domain and integration events. -->
    <dependency>
      <groupId>com.aipersimmon.ddd</groupId>
      <artifactId>aipersimmon-ddd-events-spring</artifactId>
    </dependency>
    <!-- CQRS command/query buses; registers the handlers and routes to them. -->
    <dependency>
      <groupId>com.aipersimmon.ddd</groupId>
      <artifactId>aipersimmon-ddd-cqrs-spring</artifactId>
    </dependency>
    <!--
      Web-layer contract: maps DomainException/ApplicationException and validation
      failures to RFC 9457 ProblemDetail responses, plus a trace-id filter. These
      zero-risk concerns are auto-configured on and replace a hand-written advice.
    -->
    <dependency>
      <groupId>com.aipersimmon.ddd</groupId>
      <artifactId>aipersimmon-ddd-web-spring</artifactId>
    </dependency>
    <!-- Durable Process Manager runtime: wires the order-fulfilment definition + codecs
         into the JDBC runtime, relay, and deadline worker over the app's DataSource. -->
    <dependency>
      <groupId>com.aipersimmon.ddd</groupId>
      <artifactId>aipersimmon-ddd-process-manager-jdbc-spring-boot-starter</artifactId>
    </dependency>
    <!-- Auto-applies the aipersimmon schema (here: the four process-manager tables) at startup
         via Flyway, on a dedicated history table — replaces a hand-copied schema.sql. -->
    <dependency>
      <groupId>com.aipersimmon.ddd</groupId>
      <artifactId>aipersimmon-ddd-flyway</artifactId>
    </dependency>
    <!-- Flyway 10+ ships PostgreSQL support as a separate module (this app runs on PostgreSQL). -->
    <dependency>
      <groupId>org.flywaydb</groupId>
      <artifactId>flyway-database-postgresql</artifactId>
    </dependency>

    <!--
      Reliable integration-event transport (decision-00006 "方式三": broker + outbox).
      With an outbox storage on the classpath, the IntegrationEvents port is backed by the
      transactional OutboxWriter (same-tx write) instead of the in-process events-spring
      publisher, and the ShedLock-guarded relay drains it. The Kafka module overrides the
      relay's dispatcher to publish CloudEvents to a topic and (consumer.enabled=true)
      registers the inbox-guarded consumer bridge that republishes in process — so the
      existing @EventListener handlers are untouched. The inbox de-dups the consumer side.
      All three tables (outbox + dead-letter + shedlock, inbox) come from the flyway starter.
      Full MyBatis-Plus stack (plan-00007): outbox/inbox use the -mybatis-plus variants so they
      share one SqlSessionFactory / DataSource with the aggregate mappers — aggregate write and
      outbox write commit in the same transaction. (Table shapes are identical to the -jdbc
      variants; flyway.components is unchanged.)
    -->
    <dependency>
      <groupId>com.aipersimmon.ddd</groupId>
      <artifactId>aipersimmon-ddd-outbox-mybatis-plus</artifactId>
    </dependency>
    <dependency>
      <groupId>com.aipersimmon.ddd</groupId>
      <artifactId>aipersimmon-ddd-inbox-mybatis-plus</artifactId>
    </dependency>
    <dependency>
      <groupId>com.aipersimmon.ddd</groupId>
      <artifactId>aipersimmon-ddd-messaging-kafka</artifactId>
    </dependency>
    <!-- MyBatis-Plus: provides the SqlSessionFactory the outbox/inbox variants and the aggregate
         mappers share. Version pinned here — the scaffold inherits spring-boot-starter-parent (not
         the library parent), which does not manage MyBatis-Plus. -->
    <dependency>
      <groupId>com.baomidou</groupId>
      <artifactId>mybatis-plus-spring-boot3-starter</artifactId>
      <version>3.5.15</version>
    </dependency>

    <!--
      Observability: binds the framework-free observability SPIs to OpenTelemetry and pulls in the
      OpenTelemetry Spring Boot starter (boundary auto-instrumentation for HTTP/JDBC/Kafka, plus
      logback-MDC and Micrometer exemplar bridges). Traces are exported over OTLP to the SigNoz
      otel-collector (otel.exporter.otlp.endpoint). Activated purely by being on the classpath; the
      whole domain spine stays no-op if this module is absent.
    -->
    <dependency>
      <groupId>com.aipersimmon.ddd</groupId>
      <artifactId>aipersimmon-ddd-observability-otel-spring-boot-starter</artifactId>
    </dependency>
    <!-- PostgreSQL for the four process tables; started from compose.yaml by spring-boot-docker-compose. -->
    <dependency>
      <groupId>org.postgresql</groupId>
      <artifactId>postgresql</artifactId>
      <scope>runtime</scope>
    </dependency>
    <dependency>
      <groupId>org.springframework.boot</groupId>
      <artifactId>spring-boot-docker-compose</artifactId>
      <scope>runtime</scope>
      <optional>true</optional>
    </dependency>

    <dependency>
      <groupId>org.springframework.boot</groupId>
      <artifactId>spring-boot-starter</artifactId>
    </dependency>
    <!--
      Bean Validation provider (Hibernate Validator). Bringing it onto the classpath
      is what activates the command bus's ValidationCommandInterceptor (auto-wired
      only when a provider is present) and makes @Valid on inbound DTOs effective.
      Without it, JSR 380 annotations on commands are silently inert.
    -->
    <dependency>
      <groupId>org.springframework.boot</groupId>
      <artifactId>spring-boot-starter-validation</artifactId>
    </dependency>

    <dependency>
      <groupId>org.springframework.boot</groupId>
      <artifactId>spring-boot-starter-test</artifactId>
      <scope>test</scope>
    </dependency>
    <dependency>
      <groupId>com.aipersimmon.ddd</groupId>
      <artifactId>aipersimmon-ddd-archunit</artifactId>
      <scope>test</scope>
    </dependency>
    <!-- Acceptance tests run against a real PostgreSQL via Testcontainers (@ServiceConnection). -->
    <dependency>
      <groupId>org.springframework.boot</groupId>
      <artifactId>spring-boot-testcontainers</artifactId>
      <scope>test</scope>
    </dependency>
    <dependency>
      <groupId>org.testcontainers</groupId>
      <artifactId>postgresql</artifactId>
      <scope>test</scope>
    </dependency>
    <!-- Acceptance tests exercise the real broker hop over a Kafka container (@ServiceConnection). -->
    <dependency>
      <groupId>org.testcontainers</groupId>
      <artifactId>kafka</artifactId>
      <scope>test</scope>
    </dependency>
    <dependency>
      <groupId>org.testcontainers</groupId>
      <artifactId>junit-jupiter</artifactId>
      <scope>test</scope>
    </dependency>
  </dependencies>

  <build>
    <plugins>
      <plugin>
        <groupId>org.springframework.boot</groupId>
        <artifactId>spring-boot-maven-plugin</artifactId>
      </plugin>
    </plugins>
  </build>
</project>
