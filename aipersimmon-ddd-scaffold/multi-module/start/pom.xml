<?xml version="1.0" encoding="UTF-8"?>
<project xmlns="http://maven.apache.org/POM/4.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 https://maven.apache.org/xsd/maven-4.0.0.xsd">
  <modelVersion>4.0.0</modelVersion>

  <parent>
    <groupId>com.example</groupId>
    <artifactId>multi-module</artifactId>
    <version>0.0.1-SNAPSHOT</version>
    <relativePath>../pom.xml</relativePath>
  </parent>

  <!--
    The bootstrap module: the Spring Boot application that assembles every layer
    into one deployable, and the home of the architecture tests that verify the
    whole context (layering rules via bytecode, package-info presence via source).
  -->
  <artifactId>start</artifactId>
  <name>start</name>
  <description>Spring Boot bootstrap and architecture tests for the ordering context.</description>

  <dependencies>
    <dependency><groupId>${project.groupId}</groupId><artifactId>ordering-api</artifactId></dependency>
    <dependency><groupId>${project.groupId}</groupId><artifactId>ordering-domain</artifactId></dependency>
    <dependency><groupId>${project.groupId}</groupId><artifactId>ordering-application</artifactId></dependency>
    <dependency><groupId>${project.groupId}</groupId><artifactId>ordering-infrastructure</artifactId></dependency>
    <dependency><groupId>${project.groupId}</groupId><artifactId>ordering-adapter</artifactId></dependency>

    <dependency><groupId>${project.groupId}</groupId><artifactId>inventory-api</artifactId></dependency>
    <dependency><groupId>${project.groupId}</groupId><artifactId>inventory-domain</artifactId></dependency>
    <dependency><groupId>${project.groupId}</groupId><artifactId>inventory-application</artifactId></dependency>
    <dependency><groupId>${project.groupId}</groupId><artifactId>inventory-infrastructure</artifactId></dependency>
    <dependency><groupId>${project.groupId}</groupId><artifactId>inventory-adapter</artifactId></dependency>

    <!-- In-process synchronous transport for both domain and integration events. -->
    <dependency>
      <groupId>com.aipersimmon.ddd</groupId>
      <artifactId>aipersimmon-ddd-events-spring</artifactId>
    </dependency>
    <!-- CQRS command/query buses; registers the handlers and routes to them. -->
    <dependency>
      <groupId>com.aipersimmon.ddd</groupId>
      <artifactId>aipersimmon-ddd-cqrs-spring</artifactId>
    </dependency>
    <!--
      Web-layer contract: maps DomainException/ApplicationException and validation
      failures to RFC 9457 ProblemDetail responses, plus a trace-id filter. These
      zero-risk concerns are auto-configured on and replace a hand-written advice.
    -->
    <dependency>
      <groupId>com.aipersimmon.ddd</groupId>
      <artifactId>aipersimmon-ddd-web-spring</artifactId>
    </dependency>

    <dependency>
      <groupId>org.springframework.boot</groupId>
      <artifactId>spring-boot-starter</artifactId>
    </dependency>

    <dependency>
      <groupId>org.springframework.boot</groupId>
      <artifactId>spring-boot-starter-test</artifactId>
      <scope>test</scope>
    </dependency>
    <dependency>
      <groupId>com.aipersimmon.ddd</groupId>
      <artifactId>aipersimmon-ddd-archunit</artifactId>
      <scope>test</scope>
    </dependency>
  </dependencies>

  <build>
    <plugins>
      <plugin>
        <groupId>org.springframework.boot</groupId>
        <artifactId>spring-boot-maven-plugin</artifactId>
      </plugin>
    </plugins>
  </build>
</project>
