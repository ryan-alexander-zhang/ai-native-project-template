<?xml version="1.0" encoding="UTF-8"?>
<project xmlns="http://maven.apache.org/POM/4.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 https://maven.apache.org/xsd/maven-4.0.0.xsd">
  <modelVersion>4.0.0</modelVersion>

  <parent>
    <groupId>com.example</groupId>
    <artifactId>multi-module</artifactId>
    <version>0.0.1-SNAPSHOT</version>
    <relativePath>../../pom.xml</relativePath>
  </parent>

  <!--
    Interface layer of the inventory context. Its inbound adapter reacts to the
    ordering context's published event and drives the reserve-stock use case.
  -->
  <artifactId>inventory-adapter</artifactId>
  <name>inventory-adapter</name>
  <description>Inbound messaging adapter of the inventory context.</description>

  <dependencies>
    <dependency>
      <groupId>${project.groupId}</groupId>
      <artifactId>inventory-application</artifactId>
    </dependency>
    <!-- This context's own published contract: the ipc adapter implements the
         StockAvailabilityApi Open Host Service defined here. -->
    <dependency>
      <groupId>${project.groupId}</groupId>
      <artifactId>inventory-api</artifactId>
    </dependency>
    <!-- Sends the ReserveStock command through the command bus. -->
    <dependency>
      <groupId>com.aipersimmon.ddd</groupId>
      <artifactId>aipersimmon-ddd-cqrs</artifactId>
    </dependency>
    <!-- Cross-context: consumes ordering's published contract. -->
    <dependency>
      <groupId>${project.groupId}</groupId>
      <artifactId>ordering-api</artifactId>
    </dependency>
    <dependency>
      <groupId>org.springframework</groupId>
      <artifactId>spring-context</artifactId>
    </dependency>
  </dependencies>
</project>
