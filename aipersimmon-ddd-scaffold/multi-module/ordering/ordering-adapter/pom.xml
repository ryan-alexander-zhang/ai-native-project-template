<?xml version="1.0" encoding="UTF-8"?>
<project xmlns="http://maven.apache.org/POM/4.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 https://maven.apache.org/xsd/maven-4.0.0.xsd">
  <modelVersion>4.0.0</modelVersion>

  <parent>
    <groupId>com.example</groupId>
    <artifactId>multi-module</artifactId>
    <version>0.0.1-SNAPSHOT</version>
    <relativePath>../../pom.xml</relativePath>
  </parent>

  <!--
    The interface layer: inbound adapters that drive use cases — a REST API over
    HTTP and a messaging listener for cross-context integration events. It depends
    inward on the application layer only: inbound adapters translate a transport
    into a command/query and never reference the context's own domain types (those
    are consumed by application-layer subscribers instead).
  -->
  <artifactId>ordering-adapter</artifactId>
  <name>ordering-adapter</name>
  <description>Inbound web adapter of the ordering context.</description>

  <dependencies>
    <dependency>
      <groupId>${project.groupId}</groupId>
      <artifactId>ordering-application</artifactId>
    </dependency>
    <!-- Library core: the @InterfaceLayer marker and DomainException. -->
    <dependency>
      <groupId>com.aipersimmon.ddd</groupId>
      <artifactId>aipersimmon-ddd-core</artifactId>
    </dependency>
    <!-- Command and query buses used by the controller. -->
    <dependency>
      <groupId>com.aipersimmon.ddd</groupId>
      <artifactId>aipersimmon-ddd-cqrs</artifactId>
    </dependency>
    <!-- Cross-context: consumes inventory's published contract (stock reserved/failed/released). -->
    <dependency>
      <groupId>${project.groupId}</groupId>
      <artifactId>inventory-api</artifactId>
    </dependency>
    <!-- Cross-context: consumes payment's published contract (payment authorised/declined). -->
    <dependency>
      <groupId>${project.groupId}</groupId>
      <artifactId>payment-api</artifactId>
    </dependency>
    <dependency>
      <groupId>org.springframework.boot</groupId>
      <artifactId>spring-boot-starter-web</artifactId>
    </dependency>
    <!-- Bean Validation API for @Valid on the controller and constraints on request
         DTOs. The provider is supplied by the start module at runtime; here we only
         compile against the API. -->
    <dependency>
      <groupId>jakarta.validation</groupId>
      <artifactId>jakarta.validation-api</artifactId>
    </dependency>

    <!-- Web-slice test toolchain and a Bean Validation provider so @WebMvcTest can
         exercise @Valid in isolation, with the command bus mocked. -->
    <dependency>
      <groupId>org.springframework.boot</groupId>
      <artifactId>spring-boot-starter-validation</artifactId>
      <scope>test</scope>
    </dependency>
    <dependency>
      <groupId>org.springframework.boot</groupId>
      <artifactId>spring-boot-starter-test</artifactId>
      <scope>test</scope>
    </dependency>
  </dependencies>
</project>
