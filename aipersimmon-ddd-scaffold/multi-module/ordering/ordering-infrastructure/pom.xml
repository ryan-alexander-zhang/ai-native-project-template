<?xml version="1.0" encoding="UTF-8"?>
<project xmlns="http://maven.apache.org/POM/4.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 https://maven.apache.org/xsd/maven-4.0.0.xsd">
  <modelVersion>4.0.0</modelVersion>

  <parent>
    <groupId>com.example</groupId>
    <artifactId>multi-module</artifactId>
    <version>0.0.1-SNAPSHOT</version>
    <relativePath>../../pom.xml</relativePath>
  </parent>

  <!--
    The infrastructure layer: technical implementations of the domain and
    application ports. Here the repositories are kept in memory so the project
    runs without a database; a real datastore replaces them without touching the
    domain or application.
  -->
  <artifactId>ordering-infrastructure</artifactId>
  <name>ordering-infrastructure</name>
  <description>Technical port implementations of the ordering context (in-memory).</description>

  <dependencies>
    <dependency>
      <groupId>${project.groupId}</groupId>
      <artifactId>ordering-domain</artifactId>
    </dependency>
    <!-- The in-memory saga store implements a saga port over the application's saga state. -->
    <dependency>
      <groupId>${project.groupId}</groupId>
      <artifactId>ordering-application</artifactId>
    </dependency>
    <dependency>
      <groupId>com.aipersimmon.ddd</groupId>
      <artifactId>aipersimmon-ddd-saga</artifactId>
    </dependency>
    <dependency>
      <groupId>org.springframework</groupId>
      <artifactId>spring-context</artifactId>
    </dependency>
  </dependencies>
</project>
