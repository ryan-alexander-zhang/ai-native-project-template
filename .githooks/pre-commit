#!/bin/sh
# Block committing docs still in an intermediate 'draft' status.
# A doc must be reviewed and promoted (living -> active, work item -> open)
# or resolved before it is committed. See "Document Status Workflow" in AGENTS.md.
#
# Enable once per clone:  git config core.hooksPath .githooks
# Bypass intentionally:   git commit --no-verify

fail=0
for f in $(git diff --cached --name-only --diff-filter=ACM | grep -E '\.md$'); do
  case "$f" in
    TEMPLATE.md|*/TEMPLATE.md|README.md|*/README.md) continue ;;
  esac
  # Match a real status value 'draft' (sole value), not an enum like
  # 'status: draft|active|archived'.
  if git show ":$f" | grep -Eq '^status:[[:space:]]*draft[[:space:]]*$'; then
    echo "  $f is still 'draft'"
    fail=1
  fi
done

if [ "$fail" -ne 0 ]; then
  echo
  echo "Commit aborted: the docs above are still in 'draft'."
  echo "Promote them after review (living -> active, work item -> open/resolved),"
  echo "or re-run with --no-verify to intentionally save work in progress."
  exit 1
fi

# On a lang/* branch, the docs-system skeleton (.template-sync.json "frozen")
# is owned by main and must not be edited here. This mirrors the CI gate so the
# rejection happens locally. Change those files on main, then run
# scripts/sync-docs.sh. Bypass intentionally with --no-verify.
branch=$(git rev-parse --abbrev-ref HEAD 2>/dev/null || echo "")
case "$branch" in
  lang/*)
    if [ -f .template-sync.json ] && command -v jq >/dev/null 2>&1; then
      globs=$(jq -r '.frozen[]' .template-sync.json)
      # shellcheck disable=SC2086
      frozen=$(git diff --cached --name-only --diff-filter=ACMRD -- $globs)
      if [ -n "$frozen" ]; then
        echo "Commit aborted: these docs-system files are owned by main and"
        echo "cannot be changed on branch '$branch':"
        echo "$frozen" | sed 's/^/  /'
        echo "Make the change on main, then run scripts/sync-docs.sh."
        exit 1
      fi
    fi
    ;;
esac
