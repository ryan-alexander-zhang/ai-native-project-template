<?xml version="1.0" encoding="UTF-8"?>
<project xmlns="http://maven.apache.org/POM/4.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 https://maven.apache.org/xsd/maven-4.0.0.xsd">
  <modelVersion>4.0.0</modelVersion>

  <parent>
    <groupId>com.aipersimmon.ddd</groupId>
    <artifactId>aipersimmon-ddd-parent</artifactId>
    <version>0.1.0-SNAPSHOT</version>
    <relativePath>../pom.xml</relativePath>
  </parent>

  <!--
    Transactional-outbox starter over JdbcTemplate. It implements the
    integration-event publisher port by inserting a row into an outbox table in
    the caller's transaction (atomic with the aggregate change), and a scheduled
    relay dispatches unsent rows to a broker port and marks them sent.

    Deliberately JDBC, not JPA: it defines no @Entity and touches no @EntityScan,
    so it never overrides a consumer's own entity scanning. The consumer creates
    the outbox table. The DDL ships (in aipersimmon-ddd-outbox) as vendor-templated
    Flyway migrations under aipersimmon/db/migration/outbox/{vendor} (the single
    source) — apply them via the optional shared aipersimmon-ddd-flyway starter, or
    copy them into your own Flyway/Liquibase.

    Delivery is at-least-once: a crash between dispatch and marking a row sent
    causes a redelivery, so consumers must be idempotent.
  -->
  <artifactId>aipersimmon-ddd-outbox-jdbc</artifactId>
  <name>aipersimmon-ddd-outbox-jdbc</name>
  <description>Transactional-outbox starter over JdbcTemplate for reliable integration-event delivery.</description>

  <dependencies>
    <dependency>
      <groupId>com.aipersimmon.ddd</groupId>
      <artifactId>aipersimmon-ddd-outbox</artifactId>
      <version>${project.version}</version>
    </dependency>
    <!-- Observability SPI (framework-free, no-op default): capture the trace context when a
         row is written and restore it (as a linked span) when the relay dispatches. -->
    <dependency>
      <groupId>com.aipersimmon.ddd</groupId>
      <artifactId>aipersimmon-ddd-observability</artifactId>
      <version>${project.version}</version>
    </dependency>
    <dependency>
      <groupId>com.aipersimmon.ddd</groupId>
      <artifactId>aipersimmon-ddd-application</artifactId>
      <version>${project.version}</version>
    </dependency>
    <dependency>
      <groupId>com.aipersimmon.ddd</groupId>
      <artifactId>aipersimmon-ddd-integration</artifactId>
      <version>${project.version}</version>
    </dependency>
    <dependency>
      <groupId>org.springframework.boot</groupId>
      <artifactId>spring-boot-starter-jdbc</artifactId>
    </dependency>
    <dependency>
      <groupId>org.springframework.boot</groupId>
      <artifactId>spring-boot-autoconfigure</artifactId>
    </dependency>
    <dependency>
      <groupId>com.fasterxml.jackson.core</groupId>
      <artifactId>jackson-databind</artifactId>
    </dependency>
    <!-- ShedLock: runs the scheduled relay on a single instance at a time so a
         multi-instance deployment does not poll and dispatch the same rows N times. -->
    <dependency>
      <groupId>net.javacrumbs.shedlock</groupId>
      <artifactId>shedlock-spring</artifactId>
    </dependency>
    <dependency>
      <groupId>net.javacrumbs.shedlock</groupId>
      <artifactId>shedlock-provider-jdbc-template</artifactId>
    </dependency>

    <dependency>
      <groupId>org.springframework.boot</groupId>
      <artifactId>spring-boot-starter-test</artifactId>
      <scope>test</scope>
    </dependency>
    <dependency>
      <groupId>com.h2database</groupId>
      <artifactId>h2</artifactId>
      <scope>test</scope>
    </dependency>
  </dependencies>
</project>
