<?xml version="1.0"?>
<ruleset name="aipersimmon-ddd-quality"
         xmlns="http://pmd.sourceforge.net/ruleset/2.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://pmd.sourceforge.net/ruleset/2.0.0 https://pmd.sourceforge.io/ruleset_2_0_0.xsd">

  <description>
    AiPersimmon DDD complexity and duplication rules (design-00007). Focused on the
    signals that matter for a framework-free building-block library: cognitive and
    cyclomatic complexity, NPath, method/class size, and parameter lists. Kept narrow
    on purpose — style/formatting is owned by Spotless (google-java-format), architecture
    by ArchUnit, bytecode defects by SpotBugs. Thresholds start permissive and are
    ratcheted per plan-00009.
  </description>

  <!--
    Complexity policy (plan-00009 ratchet). Two rules stay strict as the real readability guards:
    CognitiveComplexity at its default 15, and CyclomaticComplexity at 15 (the widely-accepted
    upper bound; the classic default is 10). A method that exceeds these is refactored, not tuned
    around. ExcessiveParameterList and TooManyMethods are raised because their high counts come
    from patterns that are correct rather than tangled — DI-heavy constructors / @Bean factories
    (many injected collaborators, not data) and per-item classes (config @Bean factories,
    DAO-per-query stores, one-@ExceptionHandler-per-exception, codec / state-machine handlers).
    NPathComplexity stays at its default (200): a method over it is refactored or explicitly
    suppressed with a reason, not tuned around. CyclomaticComplexity + CognitiveComplexity are
    the primary difficulty guards.
  -->
  <rule ref="category/java/design.xml/CognitiveComplexity"/>
  <rule ref="category/java/design.xml/CyclomaticComplexity">
    <properties>
      <property name="methodReportLevel" value="15"/>
    </properties>
  </rule>
  <rule ref="category/java/design.xml/NPathComplexity"/>
  <rule ref="category/java/design.xml/NcssCount"/>
  <rule ref="category/java/design.xml/ExcessiveParameterList">
    <properties>
      <property name="minimum" value="18"/>
    </properties>
  </rule>
  <rule ref="category/java/design.xml/GodClass"/>
  <rule ref="category/java/design.xml/TooManyMethods">
    <properties>
      <property name="maxmethods" value="30"/>
    </properties>
  </rule>

</ruleset>
