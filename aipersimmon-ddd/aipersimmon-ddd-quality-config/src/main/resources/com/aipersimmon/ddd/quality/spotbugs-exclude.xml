<?xml version="1.0" encoding="UTF-8"?>
<!--
  SpotBugs exclude filter (design-00007 / plan-00009). Starts empty: SpotBugs is
  introduced report-only, real false positives are added here as they surface, then
  the gate is turned on. Reference the file from the plugin via its classpath path
  com/aipersimmon/ddd/quality/spotbugs-exclude.xml (this artifact on the plugin's
  own <dependency> classpath), so library and scaffolds share one filter.
-->
<FindBugsFilter
    xmlns="https://github.com/spotbugs/filter/3.0.0"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="https://github.com/spotbugs/filter/3.0.0 https://raw.githubusercontent.com/spotbugs/spotbugs/master/spotbugs/etc/findbugsfilter.xsd">

  <!--
    CT_CONSTRUCTOR_THROW — constructor throws, so the object can leave its constructor
    partially initialized (a "finalizer attack" vector). Excluded project-wide because it
    is inherent to how this codebase models domain objects, not a defect:

      * Aggregates, entities and value objects validate their invariants IN the constructor
        (the always-valid pattern, design-00003). Throwing on a broken invariant is the point;
        the alternative — an object that can exist in an invalid state — is strictly worse.
      * The classes are non-final by necessity (aggregate roots extend AbstractAggregateRoot;
        entities like OrderLine are package-private), and SpotBugs fires purely on "non-final
        class + throwing constructor". There is no untrusted-subclassing surface here.
      * The finalizer-attack vector itself is effectively dead: Object.finalize() is deprecated
        for removal since Java 9 and never overridden in this codebase.

    Not a plugin-version artefact: the known CT_CONSTRUCTOR_THROW false-positive fix
    (spotbugs/spotbugs#2710) shipped in SpotBugs core 4.8.2 and is already present in the
    4.8.6 core used by spotbugs-maven-plugin 4.8.6.6; upgrading does not suppress these.
  -->
  <Match>
    <Bug pattern="CT_CONSTRUCTOR_THROW"/>
  </Match>

  <!--
    EI_EXPOSE_REP / EI_EXPOSE_REP2 on @ConfigurationProperties holders. Spring binds these
    mutable config objects field-by-field and their getters intentionally hand back the live
    nested holder so binding can populate it; that is how relaxed binding works, not a leak.
    Matched by the *Properties naming convention (the only such types in the library). Genuine
    value carriers still copy their arrays/collections defensively, so EI_EXPOSE stays live for
    them (e.g. ProcessEffectInsert/ProcessDeadlineInsert/ProcessTransitionInsert clone their
    byte[]; BacklogSnapshot copies its Map).
  -->
  <Match>
    <Bug pattern="EI_EXPOSE_REP,EI_EXPOSE_REP2"/>
    <Class name="~.*Properties(\$.*)?"/>
  </Match>

  <!--
    EI_EXPOSE_REP2 on infrastructure beans that hold an injected collaborator by reference
    (NamedParameterJdbcTemplate/JdbcTemplate, Clock, KafkaTemplate, TransactionTemplate,
    ObjectMapper, StringRedisTemplate, other stores). Sharing the injected reference is the
    intent of constructor injection, not a defect — and these objects cannot be meaningfully
    copied. Listed explicitly rather than by package so that a future value carrier added to
    the same package is NOT silently masked; a rename simply re-surfaces the finding for
    re-triage (fail-visible, not fail-masked).
  -->
  <Match>
    <Bug pattern="EI_EXPOSE_REP,EI_EXPOSE_REP2"/>
    <Or>
      <Class name="com.aipersimmon.ddd.cqrs.spring.TransactionTemplateUnitOfWork"/>
      <Class name="com.aipersimmon.ddd.flyway.AipersimmonFlywayMigrator"/>
      <Class name="com.aipersimmon.ddd.inbox.jdbc.InboxCleanup"/>
      <Class name="com.aipersimmon.ddd.inbox.jdbc.JdbcInbox"/>
      <Class name="com.aipersimmon.ddd.messaging.kafka.KafkaIntegrationEventListener"/>
      <Class name="com.aipersimmon.ddd.messaging.kafka.KafkaOutboxDispatcher"/>
      <Class name="com.aipersimmon.ddd.outbox.InProcessOutboxDispatcher"/>
      <Class name="com.aipersimmon.ddd.outbox.jdbc.JdbcDeadLetterStore"/>
      <Class name="com.aipersimmon.ddd.outbox.jdbc.OutboxCleanup"/>
      <Class name="com.aipersimmon.ddd.outbox.jdbc.OutboxRelay"/>
      <Class name="com.aipersimmon.ddd.outbox.jdbc.OutboxWriter"/>
      <Class name="com.aipersimmon.ddd.outbox.mybatisplus.MybatisDeadLetterStore"/>
      <Class name="com.aipersimmon.ddd.outbox.mybatisplus.OutboxWriter"/>
      <Class name="com.aipersimmon.ddd.processmanager.jdbc.autoconfigure.ProcessManagerStartupValidator"/>
      <Class name="com.aipersimmon.ddd.processmanager.jdbc.autoconfigure.ProcessSchemaValidator"/>
      <Class name="com.aipersimmon.ddd.processmanager.jdbc.deadline.JdbcProcessDeadlineWorker"/>
      <Class name="com.aipersimmon.ddd.processmanager.jdbc.observe.JdbcProcessBacklog"/>
      <Class name="com.aipersimmon.ddd.processmanager.jdbc.operation.JdbcProcessOperations"/>
      <Class name="com.aipersimmon.ddd.processmanager.jdbc.relay.JdbcProcessEffectRelay"/>
      <Class name="com.aipersimmon.ddd.processmanager.jdbc.runtime.JdbcProcessQuery"/>
      <Class name="com.aipersimmon.ddd.processmanager.jdbc.runtime.JdbcProcessRuntime"/>
      <Class name="com.aipersimmon.ddd.processmanager.jdbc.store.JdbcProcessDeadlineStore"/>
      <Class name="com.aipersimmon.ddd.processmanager.jdbc.store.JdbcProcessEffectStore"/>
      <Class name="com.aipersimmon.ddd.processmanager.jdbc.store.JdbcProcessInstanceStore"/>
      <Class name="com.aipersimmon.ddd.processmanager.jdbc.store.JdbcProcessTransitionStore"/>
      <Class name="com.aipersimmon.ddd.saga.spring.JdbcDeadlineScheduler"/>
      <Class name="com.aipersimmon.ddd.web.spring.IdempotencyFilter"/>
      <Class name="com.aipersimmon.ddd.web.spring.ProblemHttpResponseWriter"/>
      <Class name="com.aipersimmon.ddd.web.spring.RateLimitFilter"/>
      <Class name="com.aipersimmon.ddd.web.spring.ReplayProtectionFilter"/>
      <Class name="com.aipersimmon.ddd.web.store.jdbc.JdbcIdempotencyStore"/>
      <Class name="com.aipersimmon.ddd.web.store.jdbc.JdbcRateLimiter"/>
      <Class name="com.aipersimmon.ddd.web.store.jdbc.JdbcReplayGuard"/>
      <Class name="com.aipersimmon.ddd.web.store.redis.RedisIdempotencyStore"/>
      <Class name="com.aipersimmon.ddd.web.store.redis.RedisRateLimiter"/>
      <Class name="com.aipersimmon.ddd.web.store.redis.RedisReplayGuard"/>
    </Or>
  </Match>
</FindBugsFilter>
