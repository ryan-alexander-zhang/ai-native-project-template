{
  "version": "v5",
  "alert": "Process Manager deadline backlog aging",
  "alertType": "METRIC_BASED_ALERT",
  "ruleType": "threshold_rule",
  "evalWindow": "5m0s",
  "frequency": "1m0s",
  "condition": {
    "compositeQuery": {
      "queryType": "builder",
      "panelType": "value",
      "queries": [
        {
          "type": "builder_query",
          "spec": {
            "name": "A",
            "signal": "metrics",
            "disabled": false,
            "aggregations": [
              {
                "metricName": "aipersimmon.process.manager.oldest.pending.deadline.age",
                "temporality": "Unspecified",
                "timeAggregation": "latest",
                "spaceAggregation": "sum"
              }
            ],
            "groupBy": [],
            "filter": {
              "expression": "service.name = '__APP__'"
            }
          }
        }
      ]
    },
    "op": "1",
    "target": 300.0,
    "matchType": "1"
  },
  "labels": {
    "severity": "warning",
    "category": "backlog",
    "service": "__APP__"
  },
  "annotations": {
    "summary": "Oldest pending deadline aging past SLO",
    "description": "aipersimmon.process.manager.oldest.pending.deadline.age > 300s for __APP__: the deadline worker is firing due deadlines late. Threshold is a placeholder — calibrate."
  }
}
