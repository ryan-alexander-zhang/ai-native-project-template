  <!--
    JDBC storage backend for the durable Process Manager. It implements the engine's four store ports
    and the ProcessClaimStrategy over Spring JdbcTemplate - the four-table store, optimistic advance,
    the SKIP LOCKED / atomic-conditional claim, and the raw-SQL schema validator - and
    auto-configures those beans plus the dialect selection. The storage-agnostic
    aipersimmon-ddd-process-manager-engine then wires the runtime, relay, and deadline worker on top;
    this module is a self-contained Spring Boot starter (auto-configuration included) and executes no
    DDL. It is the JDBC sibling of aipersimmon-ddd-process-manager-mybatis-plus; include exactly one
    Process Manager storage backend.
  -->
  <artifactId>aipersimmon-ddd-process-manager-jdbc</artifactId>
  <name>aipersimmon-ddd-process-manager-jdbc</name>
  <description>JDBC storage backend and auto-configuration for the durable Process Manager engine: four-table store, SKIP LOCKED claim, and dialect selection.</description>

  <dependencies>
