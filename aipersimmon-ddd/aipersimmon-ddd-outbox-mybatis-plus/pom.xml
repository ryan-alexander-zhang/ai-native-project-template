         xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 https://maven.apache.org/xsd/maven-4.0.0.xsd">
  <modelVersion>4.0.0</modelVersion>

  <parent>
    <groupId>com.aipersimmon.ddd</groupId>
    <artifactId>aipersimmon-ddd-parent</artifactId>
    <version>0.1.0-SNAPSHOT</version>
    <relativePath>../pom.xml</relativePath>
  </parent>

  <!--
    Transactional-outbox storage over MyBatis-Plus. It implements the
    integration-event publisher port by inserting a row into an outbox table in the
    caller's transaction (atomic with the aggregate change) through a MyBatis-Plus
    BaseMapper, and a scheduled relay dispatches unsent rows through the
    OutboxDispatcher from the storage-agnostic outbox core and marks them sent.

    For projects standardized on MyBatis-Plus: the outbox uses the same
    SqlSessionFactory, DataSource, and transaction manager as the rest of the
    persistence. It registers ONLY its own mapper (via a MapperFactoryBean), so it
    never triggers or hijacks the consumer's @MapperScan, and defines no JPA
    @Entity. The consumer creates the outbox table (a documented DDL).

    Delivery is at-least-once: a crash between dispatch and marking a row sent
    causes a redelivery, so consumers must be idempotent (see the inbox). This is
    the MyBatis-Plus sibling of aipersimmon-ddd-outbox-jdbc; include exactly one
    outbox storage starter. A broker starter (aipersimmon-ddd-messaging-kafka)
    plugs into either because both share the outbox core's dispatcher contract.
  -->
  <artifactId>aipersimmon-ddd-outbox-mybatis-plus</artifactId>
  <name>aipersimmon-ddd-outbox-mybatis-plus</name>
  <description>Transactional-outbox storage over MyBatis-Plus for reliable integration-event delivery.</description>

  <dependencies>
    <dependency>
      <groupId>com.aipersimmon.ddd</groupId>
      <artifactId>aipersimmon-ddd-outbox</artifactId>
      <version>${project.version}</version>
    </dependency>
    <dependency>
      <groupId>com.aipersimmon.ddd</groupId>
      <artifactId>aipersimmon-ddd-application</artifactId>
      <version>${project.version}</version>
    </dependency>
    <dependency>
      <groupId>com.aipersimmon.ddd</groupId>
      <artifactId>aipersimmon-ddd-integration</artifactId>
      <version>${project.version}</version>
    </dependency>
    <dependency>
      <groupId>com.baomidou</groupId>
      <artifactId>mybatis-plus-spring-boot3-starter</artifactId>
    </dependency>
    <dependency>
      <groupId>org.springframework.boot</groupId>
      <artifactId>spring-boot-autoconfigure</artifactId>
    </dependency>
    <dependency>
      <groupId>com.fasterxml.jackson.core</groupId>
      <artifactId>jackson-databind</artifactId>
    </dependency>

    <dependency>
      <groupId>org.springframework.boot</groupId>
