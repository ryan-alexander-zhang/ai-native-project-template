<?xml version="1.0" encoding="UTF-8"?>
<project xmlns="http://maven.apache.org/POM/4.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 https://maven.apache.org/xsd/maven-4.0.0.xsd">
  <modelVersion>4.0.0</modelVersion>

  <parent>
    <groupId>org.springframework.boot</groupId>
    <artifactId>spring-boot-starter-parent</artifactId>
    <version>3.5.10</version>
    <relativePath/>
  </parent>

  <groupId>com.acme.samples.s2</groupId>
  <artifactId>structure-2-multimodule</artifactId>
  <version>0.0.1-SNAPSHOT</version>
  <packaging>pom</packaging>
  <name>structure-2-multimodule</name>
  <description>Modular monolith, physical bounded contexts (Maven modules per context and layer)</description>

  <properties>
    <java.version>21</java.version>
    <mybatis-plus.version>3.5.15</mybatis-plus.version>
    <archunit.version>1.4.0</archunit.version>
  </properties>

  <modules>
    <module>shared-kernel</module>
    <module>ordering/ordering-api</module>
    <module>ordering/ordering-domain</module>
    <module>ordering/ordering-application</module>
    <module>ordering/ordering-infrastructure</module>
    <module>ordering/ordering-adapter</module>
    <module>inventory/inventory-api</module>
    <module>inventory/inventory-domain</module>
    <module>inventory/inventory-application</module>
    <module>inventory/inventory-infrastructure</module>
    <module>inventory/inventory-adapter</module>
    <module>start</module>
  </modules>

  <dependencyManagement>
    <dependencies>
      <!-- own modules -->
      <dependency><groupId>com.acme.samples.s2</groupId><artifactId>shared-kernel</artifactId><version>${project.version}</version></dependency>
      <dependency><groupId>com.acme.samples.s2</groupId><artifactId>ordering-api</artifactId><version>${project.version}</version></dependency>
      <dependency><groupId>com.acme.samples.s2</groupId><artifactId>ordering-domain</artifactId><version>${project.version}</version></dependency>
      <dependency><groupId>com.acme.samples.s2</groupId><artifactId>ordering-application</artifactId><version>${project.version}</version></dependency>
      <dependency><groupId>com.acme.samples.s2</groupId><artifactId>ordering-infrastructure</artifactId><version>${project.version}</version></dependency>
      <dependency><groupId>com.acme.samples.s2</groupId><artifactId>ordering-adapter</artifactId><version>${project.version}</version></dependency>
      <dependency><groupId>com.acme.samples.s2</groupId><artifactId>inventory-api</artifactId><version>${project.version}</version></dependency>
      <dependency><groupId>com.acme.samples.s2</groupId><artifactId>inventory-domain</artifactId><version>${project.version}</version></dependency>
      <dependency><groupId>com.acme.samples.s2</groupId><artifactId>inventory-application</artifactId><version>${project.version}</version></dependency>
      <dependency><groupId>com.acme.samples.s2</groupId><artifactId>inventory-infrastructure</artifactId><version>${project.version}</version></dependency>
      <dependency><groupId>com.acme.samples.s2</groupId><artifactId>inventory-adapter</artifactId><version>${project.version}</version></dependency>

      <!-- external -->
      <dependency>
        <groupId>com.baomidou</groupId>
        <artifactId>mybatis-plus-spring-boot3-starter</artifactId>
        <version>${mybatis-plus.version}</version>
      </dependency>
      <dependency>
        <groupId>com.tngtech.archunit</groupId>
        <artifactId>archunit-junit5</artifactId>
        <version>${archunit.version}</version>
        <scope>test</scope>
      </dependency>
    </dependencies>
  </dependencyManagement>
</project>
