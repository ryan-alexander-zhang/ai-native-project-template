{
  "mappings": [
    {
      "request": {
        "method": "GET",
        "urlPathPattern": "/pricing"
      },
      "response": {
        "status": 200,
        "headers": { "Content-Type": "application/json" },
        "jsonBody": {
          "sku": "{{request.query.sku}}",
          "unitPriceMinor": 1999,
          "currency": "USD",
          "taxRateBps": 800
        },
        "transformers": ["response-template"]
      }
    }
  ]
}
